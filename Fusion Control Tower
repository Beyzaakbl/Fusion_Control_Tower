function renderActions(){
  const q=(document.getElementById('action-search')||{value:''}).value.toLowerCase();
  let list=actions;
  if(actionFilter==='late') list=list.filter(a=>a.s==='late');
  else if(actionFilter==='open') list=list.filter(a=>a.s==='open');
  else if(actionFilter==='done') list=list.filter(a=>a.s==='done');
  else if(actionFilter==='ws') list=list.filter(a=>a.src==='ws');
  if(q) list=list.filter(a=>a.t.toLowerCase().includes(q)||a.p.toLowerCase().includes(q));
  const el=document.getElementById('action-list');
  if(!list.length){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">✓</div><div class="empty-title">Aksiyon bulunamadı</div><div class="empty-text">Seçili filtre için aksiyon yok.</div></div>`;
    return;
  }
  el.innerHTML=list.map(a=>{
    const done=a.s==='done', late=a.s==='late';
    return `<div class="action-item">
      <div class="check-box ${done?'done':''}" onclick="toggleAction(${a.id})">
        ${done?'<svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M2 4.5l2 2 3-3" stroke="#fff" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>':''}
      </div>
      <div class="action-body">
        <div class="action-title ${done?'done':''}">${a.t}</div>
        <div class="action-footer">
          <span class="tag">${a.p}</span>
          ${a.src==='ws'?'<span class="pill pill-purple" style="font-size:9px">çalıştay</span>':''}
          <span class="action-due ${late?'late':'ok'}">${late?'⚠ ':''} ${a.due}</span>
          <span style="font-size:11px;color:var(--text3)">${a.o}</span>
        </div>
      </div>
      <div style="flex-shrink:0">${pill(done?'green':late?'red':'amber')}</div>
    </div>`;}).join('');
}

function toggleAction(id){
  const a=actions.find(x=>x.id===id);
  if(a) a.s=a.s==='done'?'open':'done';
  renderActions();
}

function filterAction(f,el){
