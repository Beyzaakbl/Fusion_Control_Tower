<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fusion Control Tower</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f4f0;--surface:#fff;--surface2:#f1efe8;--border:#e4e2da;--border2:#cccac0;
  --text:#1a1a18;--text2:#5f5e5a;--text3:#97958e;
  --blue:#185fa5;--blue-bg:#e6f1fb;--blue-mid:#378add;
  --green:#3b6d11;--green-bg:#eaf3de;--green-mid:#639922;
  --amber:#854f0b;--amber-bg:#faeeda;--amber-mid:#ba7517;
  --red:#a32d2d;--red-bg:#fcebeb;--red-mid:#e24b4a;
  --purple:#534ab7;--purple-bg:#eeedfe;--purple-mid:#7f77dd;--purple-dark:#3c3489;
  --teal:#0f6e56;--teal-bg:#e1f5ee;
  --r:8px;--rl:12px;--rxl:16px;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;min-height:100vh}

/* ── LAYOUT ── */
.app{display:flex;height:100vh;overflow:hidden}
.sidebar{width:56px;background:var(--purple-dark);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:2px;flex-shrink:0;transition:width .22s ease}
.sidebar.expanded{width:220px;align-items:flex-start;padding:12px 0}
.sidebar-logo{width:36px;height:36px;border-radius:10px;background:var(--purple-mid);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;margin:0 auto 10px}
.sidebar.expanded .sidebar-logo{margin:4px 12px 12px}
.nav-group{width:100%;padding:0 6px}
.sidebar.expanded .nav-group{padding:0 8px}
.nav-label{font-size:9px;font-weight:600;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:0.8px;padding:10px 8px 4px;display:none}
.sidebar.expanded .nav-label{display:block}
.nav-item{width:44px;height:40px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;cursor:pointer;color:rgba(255,255,255,.55);transition:all .15s;position:relative;flex-shrink:0}
.sidebar.expanded .nav-item{width:100%;justify-content:flex-start;gap:9px;padding:0 10px;height:36px}
.nav-item:hover{background:rgba(255,255,255,.1);color:rgba(255,255,255,.9)}
.nav-item.active{background:rgba(255,255,255,.15);color:#fff}
.nav-item.active::before{content:'';position:absolute;left:0;top:6px;bottom:6px;width:3px;border-radius:0 3px 3px 0;background:var(--purple-mid)}
.sidebar.expanded .nav-item.active::before{left:-8px}
.nav-icon{width:18px;height:18px;flex-shrink:0;opacity:.8}
.nav-item.active .nav-icon{opacity:1}
.nav-text{font-size:12px;font-weight:500;white-space:nowrap;display:none}
.sidebar.expanded .nav-text{display:block}
.nav-badge{background:var(--red-mid);color:#fff;font-size:9px;font-weight:700;min-width:16px;height:16px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-left:auto;padding:0 4px}
.sidebar-toggle{width:36px;height:36px;border-radius:var(--r);display:flex;align-items:center;justify-content:center;cursor:pointer;color:rgba(255,255,255,.4);margin-top:auto;transition:color .15s}
.sidebar-toggle:hover{color:rgba(255,255,255,.8)}
.sidebar.expanded .sidebar-toggle{margin:4px 8px 0;width:calc(100% - 16px)}

.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ── TOPBAR ── */
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 20px;height:52px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.topbar-breadcrumb{display:flex;align-items:center;gap:6px;flex:1}
.bc-item{font-size:12px;color:var(--text3);cursor:pointer}
.bc-item:hover{color:var(--text)}
.bc-sep{color:var(--text3);font-size:11px}
.bc-current{font-size:14px;font-weight:500;color:var(--text)}
.topbar-actions{display:flex;align-items:center;gap:6px}
.avatar-sm{width:30px;height:30px;border-radius:50%;background:var(--purple-bg);color:var(--purple);font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;cursor:pointer;border:1.5px solid var(--purple-mid)}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:var(--r);border:1px solid var(--border2);background:var(--surface);color:var(--text);font-size:12px;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;font-weight:500}
.btn:hover{background:var(--surface2);border-color:var(--border2)}
.btn:active{transform:scale(.98)}
.btn-primary{background:var(--purple);color:#fff;border-color:var(--purple)}
.btn-primary:hover{background:var(--purple-dark);border-color:var(--purple-dark)}
.btn-ghost{border-color:transparent;background:transparent}
.btn-ghost:hover{background:var(--surface2);border-color:var(--border)}
.btn-sm{padding:4px 9px;font-size:11px}
.btn-icon{width:32px;height:32px;padding:0;justify-content:center}

/* ── CONTENT ── */
.content{flex:1;overflow-y:auto;padding:20px}
.page{display:none}
.page.active{display:block}

/* ── ACTION BAR ── */
.action-bar{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.action-bar-left{flex:1;display:flex;align-items:center;gap:8px;min-width:0}
.search-input{flex:1;max-width:280px;padding:7px 10px 7px 32px;border:1px solid var(--border2);border-radius:var(--r);font-size:12px;font-family:inherit;background:var(--surface);color:var(--text);outline:none;position:relative}
.search-wrap{position:relative;flex:1;max-width:280px}
.search-wrap svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--text3);pointer-events:none}
.search-wrap input{width:100%;padding:7px 10px 7px 30px;border:1px solid var(--border2);border-radius:var(--r);font-size:12px;font-family:inherit;background:var(--surface);color:var(--text);outline:none;transition:border .15s}
.search-wrap input:focus{border-color:var(--purple)}
.filter-chips{display:flex;gap:4px;flex-wrap:wrap}
.chip{padding:4px 10px;border-radius:20px;border:1px solid var(--border2);font-size:11px;cursor:pointer;background:var(--surface);color:var(--text2);transition:all .15s;font-weight:500}
.chip:hover{border-color:var(--purple);color:var(--purple)}
.chip.active{background:var(--purple-bg);border-color:var(--purple);color:var(--purple)}

/* ── METRICS ROW ── */
.metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-bottom:16px}
.metric-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);padding:14px 16px;box-shadow:var(--shadow);transition:box-shadow .15s}
.metric-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.08)}
.metric-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.metric-label{font-size:11px;color:var(--text3);font-weight:500;text-transform:uppercase;letter-spacing:0.4px}
.metric-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center}
.metric-value{font-size:28px;font-weight:600;line-height:1;margin-bottom:4px}
.metric-sub{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:4px}
.metric-trend{font-size:10px;font-weight:600;padding:1px 6px;border-radius:20px}
.trend-up{background:var(--red-bg);color:var(--red)}
.trend-ok{background:var(--green-bg);color:var(--green)}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);box-shadow:var(--shadow)}
.card-body{padding:16px}
.card-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border)}
.card-title{font-size:13px;font-weight:600;color:var(--text)}
.card-action{font-size:11px;color:var(--blue);cursor:pointer;font-weight:500}
.card-action:hover{text-decoration:underline}

/* ── GRID LAYOUTS ── */
.grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.grid-7-5{display:grid;grid-template-columns:minmax(0,7fr) minmax(0,5fr);gap:12px}
.grid-6-4{display:grid;grid-template-columns:minmax(0,6fr) minmax(0,4fr);gap:12px}

/* ── STATUS PILLS ── */
.pill{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap}
.pill::before{content:'';width:5px;height:5px;border-radius:50%}
.pill-green{background:var(--green-bg);color:var(--green)}
.pill-green::before{background:var(--green-mid)}
.pill-amber{background:var(--amber-bg);color:var(--amber)}
.pill-amber::before{background:var(--amber-mid)}
.pill-red{background:var(--red-bg);color:var(--red)}
.pill-red::before{background:var(--red-mid)}
.pill-blue{background:var(--blue-bg);color:var(--blue)}
.pill-blue::before{background:var(--blue-mid)}
.pill-purple{background:var(--purple-bg);color:var(--purple)}
.pill-purple::before{background:var(--purple-mid)}
.pill-teal{background:var(--teal-bg);color:var(--teal)}
.pill-teal::before{background:var(--teal)}
.pill-gray{background:var(--surface2);color:var(--text2)}
.pill-gray::before{background:var(--border2)}
.tag{display:inline-block;padding:1px 6px;border-radius:4px;font-size:10px;background:var(--surface2);color:var(--text2);font-weight:500}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;table-layout:fixed}
th{font-size:10px;font-weight:600;color:var(--text3);text-align:left;padding:8px 12px;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:0.4px;background:var(--surface2)}
td{font-size:12px;padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
tbody tr{transition:background .1s;cursor:default}
tbody tr:hover td{background:var(--bg)}
.td-clip{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.td-wrap{white-space:normal;line-height:1.4}

/* ── AI INSIGHT BLOCK ── */
.ai-block{border-left:3px solid var(--purple-mid);background:var(--purple-bg);border-radius:0 var(--r) var(--r) 0;padding:11px 14px;margin-bottom:14px}
.ai-block-label{font-size:10px;font-weight:700;color:var(--purple);text-transform:uppercase;letter-spacing:0.5px;display:flex;align-items:center;gap:5px;margin-bottom:5px}
.ai-block-text{font-size:12px;color:var(--text);line-height:1.6}
.ai-block-text strong{color:var(--purple);font-weight:600}

/* ── URGENCY BANNER ── */
.urgency-bar{display:flex;align-items:center;gap:10px;background:var(--red-bg);border:1px solid var(--red-mid);border-radius:var(--r);padding:9px 14px;margin-bottom:14px}
.urgency-bar svg{flex-shrink:0;color:var(--red)}
.urgency-bar-text{font-size:12px;color:var(--red);font-weight:500;flex:1}
.urgency-bar .btn{flex-shrink:0}

/* ── PROJECT LIST ITEM ── */
.proj-item{display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid var(--border);transition:background .1s;cursor:pointer}
.proj-item:last-child{border-bottom:none}
.proj-item:hover{background:var(--bg)}
.proj-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.proj-info{flex:1;min-width:0}
.proj-name{font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.proj-meta{font-size:11px;color:var(--text3);margin-top:1px}
.proj-packs{text-align:center;min-width:48px}
.proj-packs-num{font-size:16px;font-weight:600;color:var(--amber)}
.proj-packs-label{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.3px}

/* ── ACTION ITEM ── */
.action-item{display:flex;align-items:flex-start;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);transition:background .1s}
.action-item:last-child{border-bottom:none}
.action-item:hover{background:var(--bg)}
.check-box{width:16px;height:16px;border-radius:4px;border:1.5px solid var(--border2);flex-shrink:0;cursor:pointer;margin-top:1px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.check-box:hover{border-color:var(--green)}
.check-box.done{background:var(--green);border-color:var(--green)}
.action-body{flex:1;min-width:0}
.action-title{font-size:12px;font-weight:500;line-height:1.4}
.action-title.done{text-decoration:line-through;color:var(--text3)}
.action-footer{display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap}
.action-due{font-size:11px}
.action-due.late{color:var(--red);font-weight:600}
.action-due.ok{color:var(--text3)}

/* ── WORKSHOP CARD ── */
.ws-card{padding:16px;border-bottom:1px solid var(--border)}
.ws-card:last-child{border-bottom:none}
.ws-card-top{display:flex;align-items:flex-start;gap:12px}
.ws-date-block{width:42px;text-align:center;flex-shrink:0}
.ws-day{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase}
.ws-num{font-size:22px;font-weight:700;line-height:1;color:var(--text)}
.ws-mon{font-size:10px;color:var(--text3)}
.ws-info{flex:1;min-width:0}
.ws-title{font-size:13px;font-weight:600}
.ws-sub{font-size:11px;color:var(--text3);margin-top:2px}
.ws-insights{background:var(--surface2);border-radius:var(--r);padding:10px 12px;margin-top:10px}
.ws-insight{font-size:11px;line-height:1.7;color:var(--text2);display:flex;gap:7px;align-items:flex-start;padding:1px 0}
.ws-insight-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:5px}

/* ── PROGRESS BAR ── */
.progress{height:4px;border-radius:2px;background:var(--border);overflow:hidden;margin-top:5px}
.progress-fill{height:100%;border-radius:2px;transition:width .3s}

/* ── RESOURCE ROW ── */
.res-row{display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border)}
.res-row:last-child{border-bottom:none}
.avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.cap-track{flex:1;height:5px;border-radius:3px;background:var(--surface2);overflow:hidden}
.cap-fill{height:100%;border-radius:3px;transition:width .4s}

/* ── ROADMAP ── */
.phase-card{border:1px solid var(--border);border-radius:var(--rl);margin-bottom:10px;overflow:hidden;box-shadow:var(--shadow)}
.phase-header{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;user-select:none;transition:background .15s}
.phase-header:hover{background:var(--bg)}
.phase-stripe{width:4px;height:36px;border-radius:2px;flex-shrink:0}
.phase-meta{flex:1}
.phase-title{font-size:13px;font-weight:600}
.phase-timeframe{font-size:11px;color:var(--text3);margin-top:1px}
.phase-count{font-size:11px;color:var(--text3);background:var(--surface2);padding:2px 8px;border-radius:20px}
.phase-chevron{color:var(--text3);transition:transform .2s;font-size:12px}
.phase-chevron.open{transform:rotate(180deg)}
.phase-body{border-top:1px solid var(--border)}
.roadmap-item{display:flex;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border)}
.roadmap-item:last-child{border-bottom:none}
.rmap-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-top:1px}
.rmap-body{flex:1;min-width:0}
.rmap-title{font-size:12px;font-weight:600}
.rmap-desc{font-size:11px;color:var(--text2);margin-top:3px;line-height:1.5}
.rmap-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}

/* ── EMPTY STATE ── */
.empty-state{text-align:center;padding:40px 20px;color:var(--text3)}
.empty-icon{font-size:32px;margin-bottom:10px}
.empty-title{font-size:14px;font-weight:500;color:var(--text2);margin-bottom:6px}
.empty-text{font-size:12px;line-height:1.6;max-width:260px;margin:0 auto 14px}

/* ── TABS ── */
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:14px;gap:0}
.tab{padding:8px 14px;font-size:12px;cursor:pointer;color:var(--text3);border-bottom:2px solid transparent;margin-bottom:-1px;font-weight:500;transition:all .15s}
.tab:hover{color:var(--text2)}
.tab.active{color:var(--purple);border-bottom-color:var(--purple)}

/* ── TOOLTIP HINT ── */
.hint{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--text3);background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:4px 8px;cursor:default}

/* ── DIVIDER ── */
.divider{height:1px;background:var(--border);margin:12px 0}

/* ── UPLOAD ZONE ── */
.upload-zone{border:1.5px dashed var(--border2);border-radius:var(--rl);padding:28px;text-align:center;cursor:pointer;transition:all .15s;margin-bottom:14px}
.upload-zone:hover{border-color:var(--purple);background:var(--purple-bg)}
.upload-zone-icon{font-size:24px;color:var(--text3);margin-bottom:6px}
.upload-zone-text{font-size:13px;font-weight:500;color:var(--text2)}
.upload-zone-sub{font-size:11px;color:var(--text3);margin-top:3px}

/* ── NOTIF DOT ── */
.notif-dot{width:6px;height:6px;border-radius:50%;background:var(--red-mid);position:absolute;top:6px;right:6px}

/* ── BRIEFING ── */
.brief-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px}
.brief-kpi{background:var(--surface2);border-radius:var(--r);padding:10px 12px;text-align:center}
.brief-kpi-val{font-size:22px;font-weight:700;line-height:1}
.brief-kpi-label{font-size:10px;color:var(--text3);margin-top:3px;font-weight:500}
.eskalasyon{border-left:3px solid var(--red-mid);background:var(--red-bg);border-radius:0 var(--r) var(--r) 0;padding:10px 13px;margin-bottom:8px;font-size:12px;color:var(--red)}
.eskalasyon-amber{border-left-color:var(--amber-mid);background:var(--amber-bg);color:var(--amber)}

/* ── RESPONSIVE ── */
@media(max-width:768px){
  .sidebar{width:0;overflow:hidden}
  .sidebar.mobile-open{width:220px;position:fixed;z-index:100;height:100vh}
  .metrics{grid-template-columns:repeat(2,1fr)}
  .grid-7-5,.grid-6-4,.grid-2,.grid-3{grid-template-columns:1fr}
  .brief-kpis{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>
<div class="app">

<!-- ── SIDEBAR ── -->
<nav class="sidebar" id="sidebar">
  <div class="sidebar-logo" onclick="toggleSidebar()">F</div>

  <div class="nav-group">
    <div class="nav-label">Genel</div>
    <div class="nav-item active" onclick="navigate('dashboard',this)" title="Dashboard">
      <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="1" y="1" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="10" y="1" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="1" y="10" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="10" y="10" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
      <span class="nav-text">Dashboard</span>
    </div>
    <div class="nav-item" onclick="navigate('roadmap',this)" title="IT Roadmap">
      <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><path d="M2 5h14M2 9h10M2 13h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="nav-text">IT Roadmap</span>
    </div>
  </div>

  <div class="nav-group">
    <div class="nav-label">Projeler</div>
    <div class="nav-item" onclick="navigate('projects',this)" title="Tüm Projeler">
      <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="1" y="3" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M5 7h8M5 10.5h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="nav-text">Tüm Projeler</span>
      <span class="nav-badge">11</span>
    </div>
    <div class="nav-item" onclick="navigate('yug',this)" title="YÜG">
      <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><path d="M9 2L9 9M9 9L6 6M9 9L12 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 14h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
